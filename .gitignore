__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
artifacts/
mlruns/
wandb/
outputs/
multirun/
lightning_logs/
logs/
*.ckpt
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
# Keep DVC sidecar files tracked even when the data itself is ignored
!data/raw/*.dvc
!data/processed/*.dvc
!data/raw/.gitignore
!data/processed/.gitignore
.env
.env.local

# Unreal Engine
UEProject/Binaries/
UEProject/Build/
UEProject/DerivedDataCache/
UEProject/Intermediate/
UEProject/Saved/
UEProject/.vs/
UEProject/*.sln
UEProject/*.VC.db
# Plugin copy living inside the host project is build-only; source of truth is Plugin/
UEProject/Plugins/
# Transient build log captured during the compile test
UEProject/build_log.txt
UEProject/*.vsconfig
Plugin/*/Binaries/
Plugin/*/Intermediate/
